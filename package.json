{
  "name": "mcpcert",
  "version": "0.4.0",
  "description": "The test suite + trust layer for MCP servers. Start with: mcpcert doctor <server>.",
  "author": "Kislay Kumar <kislay.osho@gmail.com>",
  "homepage": "https://github.com/kislayom/mcpcert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kislayom/mcpcert.git"
  },
  "bugs": {
    "url": "https://github.com/kislayom/mcpcert/issues"
  },
  "type": "module",
  "bin": {
    "mcpcert": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testing",
    "conformance",
    "ai-agents",
    "cli"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
